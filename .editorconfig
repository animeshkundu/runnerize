root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 2

# Markdown uses trailing whitespace for hard line breaks.
[*.md]
trim_trailing_whitespace = false

# Shell scripts (including the ones embedded as heredocs in src/) must stay LF.
[*.sh]
end_of_line = lf

[Makefile]
indent_style = tab
