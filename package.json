{
  "name": "runnerize",
  "version": "0.1.1",
  "description": "Stateless, on-demand self-hosted GitHub Actions runners for your private repos: a dispatcher mints an ephemeral just-in-time runner per queued job and runs it in a throwaway rootless container.",
  "bin": {
    "runnerize": "bin/runnerize.js"
  },
  "type": "module",
  "engines": {
    "node": ">=18"
  },
  "files": [
    "bin",
    "src",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "start": "node bin/runnerize.js",
    "test": "node --test test/unit/*.test.js",
    "test:e2e": "node --test test/e2e/*.test.js",
    "test:all": "node --test test/unit/*.test.js test/e2e/*.test.js"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/animeshkundu/runnerize.git"
  },
  "homepage": "https://animeshkundu.github.io/runnerize",
  "bugs": {
    "url": "https://github.com/animeshkundu/runnerize/issues"
  },
  "keywords": [
    "github-actions",
    "self-hosted-runner",
    "actions-runner",
    "jit",
    "ephemeral",
    "ci",
    "cd",
    "runner",
    "podman",
    "container",
    "devops"
  ],
  "author": "animeshkundu",
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {}
}
